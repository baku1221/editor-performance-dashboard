# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and never committed.

# --- Google Sheets (Progress Tracker only — video counts come from Meta, not a sheet) ---
# Two ways to authenticate — set ONE of these:
#
# Option A — API key (simplest). Works only if the sheet is shared as
# "Anyone with the link can view". Get a key: Google Cloud Console →
# APIs & Services → Enable "Google Sheets API" → Credentials → Create
# Credentials → API key.
GOOGLE_SHEETS_API_KEY=
#
# Option B — Service account (for a restricted sheet). Create a service
# account + JSON key in Google Cloud Console, then share the sheet with
# its email as "Viewer".
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the private_key from the JSON key file. Keep the \n escapes literal (one line).
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Sheet ID = the long id in the sheet URL: https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
PROGRESS_TRACKER_SHEET_ID=

# Which tabs feed the Daily Progress tab, and what to label each one in the UI.
# Format: "Exact Tab Name|Label,Other Tab Name|Other Label". Columns are located by
# header name per tab, so tabs don't need identical layouts.
# Default (used if unset): the real Foreign + Lumus ad tracker tabs.
# PROGRESS_TRACKER_TABS=Ad Tracker-foreign(AT)|Foreign,Ad Tracker-foreign(LUMUS)|Lumus

# --- Meta Ads API ---
# Marketing API access token (system user or long-lived user token with ads_read).
META_ACCESS_TOKEN=
META_API_VERSION=v20.0
# Comma-separated ad account ids, e.g. act_1234567890,act_0987654321
META_AD_ACCOUNT_IDS=
# PRIORITY ORDER (not summed) of action_type names used as "conversions" for CPA/CPI.
# Meta reports the same install under multiple action_type labels (omni_app_install and
# mobile_app_install are the same underlying installs, just two attribution methods) —
# summing them double-counts. The first matching type found is used.
META_CONVERSION_ACTION_TYPES=omni_app_install,mobile_app_install
# Restrict to specific install campaigns instead of the whole account — also works around a
# real Meta bug: requesting nested creative fields on an /ads listing 500s partway through
# pagination on accounts with enough history, silently truncating the result set.
# META_CAMPAIGN_IDS=120241713469960068,120243586878400130
# Bounds both the ads fetch (by created_time) and the insights time_range. "to" is always
# today's date, recomputed live on every request. Empty = lifetime.
# META_INSIGHTS_SINCE_DATE=2026-06-01
# Maps a Meta ad account id to a human business-unit label (Performance tab sub-tabs/color themes).
# META_ACCOUNT_LABELS=act_111111111|Lumus,act_222222222|Astrotalk

# --- Video duration via Drive-link sheet (sidesteps a Meta permission wall on Video.length —
# reading video duration needs Page-level access the ads_read token doesn't have) ---
# A "<Business> AI Creatives" sheet with columns: Name, Editor, Link (Drive folder), Meta Ad ID.
# Joined by exact Meta Ad ID, no fuzzy title matching needed.
# DRIVE_CREATIVE_SHEET_ID=
# DRIVE_CREATIVE_SHEET_TABS=July 2026
# Needs the Drive API (separate from Sheets API) enabled on a Google Cloud project + a key from
# there. Duration silently stays blank until this is set.
# GOOGLE_DRIVE_API_KEY=

# Canonical editor names (comma-separated), used to normalize whatever's parsed out of ad
# titles or the Progress Tracker sheet's Editor column. Format per entry: "Name|alias1|alias2"
# for name variants seen in real data (spelling drift, typos) that should still map to the
# same editor. Anything that matches NO entry here lands in "Unmapped" rather than becoming
# its own fake editor. Leave unset to use the raw parsed name as-is (no roster validation).
# EDITOR_ROSTER=Parul,Aditya Gupta,Karan,Khushboo|Khusboo,Roshan

# --- Winning Creative rule (configurable, no code change needed) ---
# metric: spend | cpi | cpa | ctr | cpc | cpm
WINNING_RULE_METRIC=cpi
# operator: lt | gt | lte | gte
WINNING_RULE_OPERATOR=lt
WINNING_RULE_VALUE=350

# --- Auto-sync (runs inside the app itself — see src/instrumentation.ts) ---
# Only fires while the server process is actually up, so this needs hosting on a persistent
# process (a VPS/Docker/Render-or-Railway "Web Service"), not a serverless platform where
# instances come and go — see cache/store.ts for why the in-memory data model needs that anyway.
AUTO_SYNC_ENABLED=true
# Fires once at least this many hours have passed since the last sync — manual ("Sync now") or
# automatic, whichever was most recent. Checked every 5 minutes.
AUTO_SYNC_INTERVAL_HOURS=12
